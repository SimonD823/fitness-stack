# ============================================================
# Local AI Fitness Stack — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to GitHub — it is in .gitignore.
# ============================================================

# ── Network ──────────────────────────────────────────────────
NAS_HOST=nas
NAS_IP=192.168.1.x
MAX_HOST=max
MAX_IP=192.168.1.x

# ── InfluxDB ─────────────────────────────────────────────────
INFLUX_PORT=8086
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASS=changeme
INFLUX_USER=influxdb_user
INFLUX_PASS=changeme

# ── Garmin ───────────────────────────────────────────────────
GARMIN_EMAIL=your_garmin_email@example.com
GARMIN_PASSWORD=
GARMIN_DISPLAY_NAME=YourDisplayName

# ── LM Studio ────────────────────────────────────────────────
LM_MODEL=qwen/qwen3.6-27b

# ── Email (Brevo) ─────────────────────────────────────────────
BREVO_API_KEY=YOUR_BREVO_API_KEY
EMAIL_FROM=your_brevo_login@smtp-brevo.com
EMAIL_FROM_NAME=AI Fitness Coach
EMAIL_TO=your_email@example.com

# ── Training ─────────────────────────────────────────────────
# TRAINING_WEEK is auto-calculated from plan start date.
# Override here only if you need to manually correct it.
# TRAINING_WEEK=2

# ── Daily Brief Schedule ─────────────────────────────────────
SEND_HOUR=6
SEND_MINUTE=45
RUN_NOW=false
